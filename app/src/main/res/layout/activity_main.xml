<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BillWiser Calculator"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#005CA9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Electricity Bill Estimator &amp; Tracker"
                android:textSize="14sp"
                android:textColor="#777777"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="18dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Billing Month"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerMonth"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="18dp"
                android:entries="@array/months_array"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Electricity Consumption (kWh)"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etKwh"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Enter units (1 - 1000)"
                android:inputType="numberDecimal"
                android:paddingLeft="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginBottom="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rebate Rate"
                    android:textStyle="bold"
                    android:textColor="#333333" />

                <TextView
                    android:id="@+id/tvRebateValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textStyle="bold"
                    android:textColor="#005CA9" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekBarRebate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="5"
                android:progress="0"
                android:layout_marginBottom="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E6F0FA"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTotalCharges"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Charges: RM 0.00"
                android:textSize="15sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvFinalCost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Final Cost: RM 0.00"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#005CA9" />
        </LinearLayout>

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Calculate &amp; Save"
            android:textStyle="bold"
            android:textSize="16sp"
            android:backgroundTint="#005CA9"
            android:layout_marginBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnViewHistory"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="View History"
                android:backgroundTint="#424242"
                android:layout_marginRight="6dp"/>

            <Button
                android:id="@+id/btnAbout"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginLeft="6dp"
                android:layout_weight="1"
                android:backgroundTint="#424242"
                android:text="About " />
        </LinearLayout>

    </LinearLayout>
</ScrollView>