<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="About Developer"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#005CA9"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"/>

    <ImageView
        android:id="@+id/imgProfile"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/img_2"
        android:contentDescription="Developer Profile" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="16dp"
        android:elevation="2dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NUR EILZHRAA BINTI MOHD SHAMSUDDIN"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:layout_gravity="center"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student ID: 2025148573"
            android:textColor="#555555"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Course: ICT602"
            android:textColor="#555555"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Program: Mobile Technology and Development"
            android:textColor="#555555"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Find Me Here"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="#333333"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvGithubUrl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="https://github.com/Eilzhraa"
        android:textColor="#005CA9"
        android:textSize="14sp"
        android:textStyle="bold|italic"
        android:padding="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="16dp"
        android:elevation="2dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Application User Guide Instructions"
            android:textStyle="bold"
            android:textColor="#005CA9"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Choose the targeting billing month via the spinner selection drop down.\n\n2. Fill out the consumption unit entry using positive numbers (1 to 1000 kWh).\n\n3. Slide the horizontal slider bar to assign a rebate configuration (0% - 5%).\n\n4. Press the 'Calculate and Save' button to view immediate computations and log records.\n\n5. Press the 'View History' action element to review historical databases inside an isolated interface view layout.\n\n6. Select any individual record logs list elements to prompt view detail options, update entries, or clear selected data out of the system."
            android:textColor="#444444"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.1"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnAboutBack"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Back to Dashboard"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#005CA9"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="© 2026 All Rights Reserved"
        android:textColor="@android:color/darker_gray"
        android:textSize="12sp"
        android:layout_marginBottom="12dp"/>
</LinearLayout>
</ScrollView>