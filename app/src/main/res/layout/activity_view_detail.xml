<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <!-- HEADER HALAMAN -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Full Invoice Details"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#005CA9"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"/>

    <!-- KAD RESIT DIGITAL PUTIH -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="20dp"
        android:layout_marginBottom="32dp">

        <!-- Baris 1: ID Rekod & Bulan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ID: #--"
                android:textColor="#888888"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Month: --"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#333333" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EAEAEA"
            android:layout_marginBottom="16dp"/>

        <!-- Baris 2: Penggunaan Kuasa -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Power Consumption"
                android:textColor="#666666"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvKwh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- kWh"
                android:textColor="#333333"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Baris 3: Rebat Applied -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rebate Applied"
                android:textColor="#666666"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvRebate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--%"
                android:textColor="#388E3C"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Baris 4: Kos Asas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Base Charges"
                android:textColor="#666666"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RM 0.00"
                android:textColor="#333333"
                android:textSize="16sp"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#005CA9"
            android:layout_marginBottom="16dp"/>

        <!-- Baris 5: Kos Akhir (Final) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Final Cost "
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFinal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RM 0.00"
                android:textColor="#005CA9"
                android:textStyle="bold"
                android:textSize="22sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- BUTANG BACK -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Back to History List"
        android:textStyle="bold"
        android:textSize="16sp"
        android:backgroundTint="#424242" />

</LinearLayout>